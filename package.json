{
  "name": "fourmolu-checker",
  "displayName": "Fourmolu Checker - Formatting Diagnostics for Haskell",
  "description": "Displays Fourmolu formatting differences as VS Code diagnostics without modifying your source files.",
  "version": "0.5.0",
  "publisher": "hugoduda",
  "author": {
    "name": "Hugo Duda"
  },
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/HugoDuda/fourmolu-checker.git"
  },
  "bugs": {
    "url": "https://github.com/HugoDuda/fourmolu-checker/issues"
  },
  "homepage": "https://github.com/HugoDuda/fourmolu-checker#readme",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "fourmolu",
    "haskell",
    "formatter"
  ],
  "scripts": {
    "test": "node --test",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "main": "./extension.js",
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onLanguage:haskell",
    "onCommand:fourmoluChecker.checkCurrentFile",
    "onCommand:fourmoluChecker.formatCurrentFile"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "fourmoluChecker.checkCurrentFile",
        "title": "Fourmolu Checker: Check Current File"
      },
      {
        "command": "fourmoluChecker.formatCurrentFile",
        "title": "Fourmolu Checker: Format Current File"
      }
    ],
    "configuration": {
      "title": "Fourmolu Checker",
      "properties": {
        "fourmoluChecker.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Enable Fourmolu formatting diagnostics."
        },
        "fourmoluChecker.checkOnSave": {
          "type": "boolean",
          "default": true,
          "scope": "resource",
          "description": "Check matching Haskell files after they are saved and when a clean file is opened."
        },
        "fourmoluChecker.diagnosticSeverity": {
          "type": "string",
          "enum": [
            "warning",
            "information"
          ],
          "default": "warning",
          "scope": "resource",
          "description": "Severity used for Fourmolu formatting diagnostics. Execution and Fourmolu failures are always reported as errors."
        },
        "fourmoluChecker.executablePath": {
          "type": "string",
          "default": "fourmolu",
          "scope": "resource",
          "description": "Fourmolu executable name or path. Relative paths are resolved from the owning workspace folder, or from the standalone file's directory."
        },
        "fourmoluChecker.include": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/*.hs"
          ],
          "scope": "resource",
          "description": "Glob patterns, relative to each workspace folder, for files to check."
        },
        "fourmoluChecker.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "**/dist-newstyle/**",
            "**/.stack-work/**"
          ],
          "scope": "resource",
          "description": "Glob patterns, relative to each workspace folder, for files to ignore."
        },
        "fourmoluChecker.extraArguments": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "description": "Additional arguments passed to Fourmolu before its mode and file arguments."
        }
      }
    }
  }
}
